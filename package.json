    "@react-navigation/stack": "^6.4.1",
    "chroma-js": "^2.4.2",
    "expo": "~54.0.33",
    "expo-font": "~14.0.11",
    "expo-haptics": "^55.0.14",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
